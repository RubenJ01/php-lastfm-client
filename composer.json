{
    "name": "rjds/php-lastfm-client",
    "description": "A client that integrates the LastFM API",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Rjds\\PhpLastfmClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rjds\\PhpLastfmClient\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Ruben Eekhof",
            "email": "rubeneekhof@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "rjds/php-dto": "^1.1"
    },
    "require-dev": {
        "phpro/grumphp": "^2.19",
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": true
        }
    }
}
